<Window x:Class="TestApp.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestApp.UI.Views"
        mc:Ignorable="d"
        Title="TestApp" Height="200" Width="400">
    
    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" 
                        VerticalAlignment="Center">

            <Button Command="{Binding OpenImportCommand}"
                        Content="Import users"
                        Padding="20,10"
                        Margin="10,10,10,10"
                        MinWidth="100"/>

            <Button Command="{Binding OpenExportCommand}"
                        Content="Export users"
                        Padding="20,10"
                        Margin="10,10,10,10"
                        MinWidth="100"/>

        </StackPanel>
    </Grid>
</Window>
